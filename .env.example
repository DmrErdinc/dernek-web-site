# Database
DATABASE_URL="postgresql://postgres:postgres@db:5432/kahramanlar_dernegi?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# Admin Default Credentials (Change after first login)
ADMIN_EMAIL="admin@kahramanlardernegi.org"
ADMIN_PASSWORD="Admin123!"

# Upload Settings
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp,image/jpg"

# Site Settings
SITE_NAME="Ölümsüz Kahramanlar Derneği"
SITE_URL="http://localhost:3000"

